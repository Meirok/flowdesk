{
  "expo": {
    "name": "FlowDesk",
    "slug": "flowdesk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "flowdesk",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f0f14",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flowdesk.app",
      "deploymentTarget": "15.0",
      "infoPlist": {
        "NSCameraUsageDescription": "FlowDesk needs camera access to scan documents.",
        "NSPhotoLibraryUsageDescription": "FlowDesk needs photo library access to attach images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f14"
      },
      "package": "com.flowdesk.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0f14",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
